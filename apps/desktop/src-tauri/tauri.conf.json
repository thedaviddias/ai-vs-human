{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI vs Human Desktop",
  "version": "0.1.0",
  "identifier": "dev.aivshuman.desktop",
  "build": {
    "beforeDevCommand": "pnpm vite dev --port 1420",
    "beforeBuildCommand": "pnpm vite build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI vs Human Desktop Sync",
        "width": 900,
        "height": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/thedaviddias/ai-vs-human/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
